<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ActivityHappyTest">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Questionário da felicidade"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/txtAtividades"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Atividades praticadas"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title" />

    <CheckBox
        android:id="@+id/atv_estudando"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estudei"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtAtividades" />

    <CheckBox
        android:id="@+id/atv_trabalhando"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trabalhei"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/atv_estudando" />

    <CheckBox
        android:id="@+id/atv_folga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Folguei"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/atv_trabalhando" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Horas de sono"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/atv_folga" />

    <RadioGroup
        android:id="@+id/radiogp_sono"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3">

        <RadioButton
            android:id="@+id/sono_baixo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0-3 horas" />

        <RadioButton android:id="@+id/sono_medio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4-8 horas" />

        <RadioButton android:id="@+id/sono_alto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8-12 horas" />

    </RadioGroup>

    <TextView
        android:id="@+id/txtEstresse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nível de estresse"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/radiogp_sono" />

    <RadioGroup
        android:id="@+id/radiogp_stress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtEstresse">

        <RadioButton
            android:id="@+id/stress_baixo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stress baixo" />
        <RadioButton
            android:id="@+id/stress_medio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stress médio" />
        <RadioButton
            android:id="@+id/stress_alto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stress alto" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_calcular"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enviar"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/radiogp_stress" />

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="592dp"
        android:text="Voltar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_calcular" />


</androidx.constraintlayout.widget.ConstraintLayout>